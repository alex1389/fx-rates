{
  "manifest_version": 3,
  "name": "Upwork Proposal Assistant",
  "version": "1.0.0",
  "description": "Review and autocomplete your Upwork proposals with AI, right on the job page.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.upwork.com/*",
    "https://api.anthropic.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.upwork.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
